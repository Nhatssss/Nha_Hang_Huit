<Application x:Class="Nha_Hang_Huit.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/frmDangNhap.xaml"
             xml:lang="vi-VN">
    <Application.Resources>
        <ResourceDictionary>

            <!-- Font mac dinh: Arial la font pho bien nhat cho tieng Viet tren Windows -->
            <FontFamily x:Key="AppFont">Arial</FontFamily>

            <!-- Mau sac chu dao: Do nau - Vang (Haidilao style) -->
            <SolidColorBrush x:Key="ColorPrimary" Color="#7B2D2D"/>
            <SolidColorBrush x:Key="ColorPrimaryDark" Color="#5C1F1F"/>
            <SolidColorBrush x:Key="ColorAccent" Color="#D4A017"/>
            <SolidColorBrush x:Key="ColorAccentHover" Color="#B8860B"/>
            <SolidColorBrush x:Key="ColorBackground" Color="#FDF5E6"/>
            <SolidColorBrush x:Key="ColorSurface" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="ColorTextPrimary" Color="#212121"/>
            <SolidColorBrush x:Key="ColorTextSecondary" Color="#5D4037"/>
            <SolidColorBrush x:Key="ColorSuccess" Color="#2E7D32"/>
            <SolidColorBrush x:Key="ColorWarning" Color="#E65100"/>
            <SolidColorBrush x:Key="ColorGoldLight" Color="#FFF8E1"/>
            <SolidColorBrush x:Key="ColorBrownLight" Color="#EFEBE9"/>

            <!-- ===== BASE STYLE: ap dung cho toan bo ung dung ===== -->
            <!-- Tat ca control mac dinh dung Arial -->
            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>
            <Style TargetType="Label">
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>
            <Style TargetType="TextBox">
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>
            <Style TargetType="PasswordBox">
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>
            <Style TargetType="Button">
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Padding" Value="12,6"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Style>
            <Style TargetType="ListBox">
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>
            <Style TargetType="ComboBox">
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>
            <Style TargetType="DataGrid">
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="AutoGenerateColumns" Value="False"/>
                <Setter Property="HeadersVisibility" Value="Column"/>
                <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            </Style>
            <!-- ListView, ListBoxItem, ComboBoxItem cung dung Arial -->
            <Style TargetType="ListBoxItem">
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>
            <Style TargetType="ComboBoxItem">
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>

            <!-- ===== NAMED STYLES ===== -->

            <!-- Button chinh (do nau) -->
            <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Background" Value="{StaticResource ColorPrimary}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource ColorPrimaryDark}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Button nhan (vang) -->
            <Style x:Key="BtnAccent" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Background" Value="{StaticResource ColorAccent}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource ColorAccentHover}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- TextBox, PasswordBox co vien -->
            <Style x:Key="TxtField" TargetType="Control">
                <Setter Property="BorderBrush" Value="#BCAAA4"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

            <!-- Label style -->
            <Style x:Key="LabelStyle" TargetType="Label">
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="Foreground" Value="{StaticResource ColorTextSecondary}"/>
                <Setter Property="Margin" Value="0,0,0,2"/>
            </Style>

            <!-- Tieu de chinh -->
            <Style x:Key="TitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="20"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="Foreground" Value="{StaticResource ColorPrimary}"/>
                <Setter Property="Margin" Value="0,0,0,10"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
