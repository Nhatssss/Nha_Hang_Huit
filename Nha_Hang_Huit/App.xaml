<Application x:Class="Nha_Hang_Huit.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             StartupUri="Views/frmDangNhap.xaml"
             xml:lang="vi-VN">
    <Application.Resources>
        <ResourceDictionary>

            <!-- Font mac dinh: Segoe UI + fallback cho tieng Viet -->
            <FontFamily x:Key="AppFont">Segoe UI, Arial, Microsoft Sans Serif</FontFamily>

            <!-- Mau sac chu dao: Do nau - Vang (Haidilao style) -->
            <SolidColorBrush x:Key="ColorPrimary" Color="#7B2D2D"/>
            <SolidColorBrush x:Key="ColorPrimaryDark" Color="#5C1F1F"/>
            <SolidColorBrush x:Key="ColorAccent" Color="#D4A017"/>
            <SolidColorBrush x:Key="ColorAccentHover" Color="#B8860B"/>
            <SolidColorBrush x:Key="ColorBackground" Color="#FDF5E6"/>
            <SolidColorBrush x:Key="ColorSurface" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="ColorTextPrimary" Color="#212121"/>
            <SolidColorBrush x:Key="ColorTextSecondary" Color="#5D4037"/>
            <SolidColorBrush x:Key="ColorSuccess" Color="#2E7D32"/>
            <SolidColorBrush x:Key="ColorWarning" Color="#E65100"/>
            <SolidColorBrush x:Key="ColorGoldLight" Color="#FFF8E1"/>
            <SolidColorBrush x:Key="ColorBrownLight" Color="#EFEBE9"/>

            <!-- ===== IMPLICIT STYLES (ap dung mac dinh cho toan bo ung dung) ===== -->

            <!-- TextBlock mac dinh -->
            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
                <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
            </Style>

            <!-- Label mac dinh -->
            <Style TargetType="Label">
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>

            <!-- TextBox mac dinh -->
            <Style TargetType="TextBox">
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

            <!-- PasswordBox mac dinh -->
            <Style TargetType="PasswordBox">
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

            <!-- ListBox mac dinh -->
            <Style TargetType="ListBox">
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>

            <!-- ComboBox mac dinh -->
            <Style TargetType="ComboBox">
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>

            <!-- Button mac dinh -->
            <Style TargetType="Button">
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Padding" Value="12,6"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Style>

            <!-- DataGrid mac dinh -->
            <Style TargetType="DataGrid">
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="AutoGenerateColumns" Value="False"/>
                <Setter Property="RowDetailsVisibilityMode" Value="VisibleWhenSelected"/>
            </Style>

            <!-- ===== NAMED STYLES (dung cho cac control dac biet) ===== -->

            <!-- Style Button chinh (do nau) -->
            <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Background" Value="{StaticResource ColorPrimary}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Padding" Value="16,8"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource ColorPrimaryDark}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Style Button nhan (vang) -->
            <Style x:Key="BtnAccent" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Background" Value="{StaticResource ColorAccent}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Padding" Value="16,8"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource ColorAccentHover}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Style TextBox va PasswordBox -->
            <Style x:Key="TxtField" TargetType="Control">
                <Setter Property="BorderBrush" Value="#BCAAA4"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

            <!-- Style Label -->
            <Style x:Key="LabelStyle" TargetType="Label">
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="Foreground" Value="{StaticResource ColorTextSecondary}"/>
                <Setter Property="Margin" Value="0,0,0,2"/>
            </Style>

            <!-- Style tieu de chinh -->
            <Style x:Key="TitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="20"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="Foreground" Value="{StaticResource ColorPrimary}"/>
                <Setter Property="Margin" Value="0,0,0,10"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
