<Window x:Class="Nha_Hang_Huit.Views.frmKhachHang"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kh&#x00E1;ch H&#x00E0;ng &amp; T&#x00ED;ch &#x0110;i&#x1EC3;m - Nh&#x00E0; H&#x00E0;ng HUIT"
        Height="560" Width="900" WindowStartupLocation="CenterScreen"
        Background="{StaticResource ColorBackground}"
        FontFamily="{StaticResource AppFont}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource ColorPrimary}" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="&#x1F465;" FontSize="28" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="KH&#x00C1;CH H&#x00C0;NG &amp; T&#x00CD;CH &#x0110;I&#x1EC2;M" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource ColorAccent}"/>
                        <TextBlock x:Name="lblTongKH" Text="T&#x1ED5;ng s&#x1ED1;: 0 kh&#x00E1;ch h&#x00E0;ng"
                                   FontSize="11" Foreground="#FFD7CCC8"/>
                    </StackPanel>
                    <TextBox Grid.Column="2" x:Name="txtSearch" Text="" Style="{StaticResource TxtField}"
                             Width="200" Height="30" FontSize="13"
                             TextChanged="txtSearch_TextChanged"/>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="320"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Customer info & new customer -->
                <Border Grid.Column="0" Background="{StaticResource ColorSurface}" CornerRadius="8" Padding="15" Margin="0,0,5,0">
                    <StackPanel>
                        <!-- Search -->
                        <TextBlock Text="T&#x00CC;M KH&#x00C1;CH H&#x00C0;NG" FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource ColorPrimary}" Margin="0,0,0,10"/>

                        <Label Content="S&#x1ED1; &#x0111;i&#x1EC7;n tho&#x1EA1;i:" Style="{StaticResource LabelStyle}"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="txtSoDienThoai" Style="{StaticResource TxtField}" FontSize="13"/>
                            <Button Grid.Column="1" x:Name="btnTim" Content="T&#x00EC;m" Style="{StaticResource BtnPrimary}"
                                    Height="34" FontSize="12" Padding="12,4" Margin="5,0,0,0" Click="btnTim_Click"/>
                        </Grid>

                        <!-- Customer info panel -->
                        <Border x:Name="panelThongTinKH" Background="{StaticResource ColorGoldLight}" CornerRadius="6"
                                Padding="10" Margin="0,0,0,10" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock x:Name="lblTenKH" FontWeight="Bold" FontSize="14"/>
                                <TextBlock x:Name="lblSDTKH" FontSize="12" Foreground="{StaticResource ColorTextSecondary}"/>
                                <Grid Margin="0,5,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#x0110;i&#x1EC3;m:" FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock Grid.Column="1" x:Name="lblDiem" Text="0" Margin="3,0,10,0" FontSize="12"/>
                                    <TextBlock Grid.Column="2" x:Name="lblHangThe" Text="H&#x1EA1;ng th&#x1EBB;: Th&#x01B0;&#x1EDD;ng" FontSize="12"/>
                                </Grid>
                                <Button x:Name="btnChonKH" Content="Ch&#x1ECD;n kh&#x00E1;ch h&#x00E0;ng n&#x00E0;y"
                                        Style="{StaticResource BtnAccent}" Height="30" FontSize="11" Margin="0,8,0,0"
                                        Padding="8,4" Click="btnChonKH_Click"/>
                            </StackPanel>
                        </Border>

                        <Separator Background="{StaticResource ColorAccent}" Height="2" Margin="0,0,0,10"/>

                        <!-- New Customer -->
                        <TextBlock Text="TH&#x00D4;NG TIN KH&#x00C1;CH M&#x1ED8;I" FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource ColorPrimary}" Margin="0,0,0,8"/>

                        <Label Content="T&#x00EA;n kh&#x00E1;ch h&#x00E0;ng:" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="txtTenKH" Style="{StaticResource TxtField}" FontSize="13" Margin="0,0,0,8"/>

                        <Label Content="S&#x1ED1; &#x0111;i&#x1EC7;n tho&#x1EA1;i:" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="txtSDTNew" Style="{StaticResource TxtField}" FontSize="13" Margin="0,0,0,12"/>

                        <Button x:Name="btnThemKH" Content="Th&#x00EA;m kh&#x00E1;ch h&#x00E0;ng m&#x1EDB;i"
                                Style="{StaticResource BtnAccent}" Height="34" FontSize="12" Click="btnThemKH_Click"/>
                    </StackPanel>
                </Border>

                <!-- Right: Customer list -->
                <Border Grid.Column="1" Background="{StaticResource ColorSurface}" CornerRadius="8" Padding="10" Margin="5,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="DANH S&#x00C1;CH KH&#x00C1;CH H&#x00C0;NG" FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource ColorPrimary}" Margin="0,0,0,8"/>
                        <ListBox Grid.Row="1" x:Name="lstKhachHang" BorderThickness="0" FontSize="13"
                                 SelectionChanged="lstKhachHang_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="6" Margin="1" Background="{StaticResource ColorGoldLight}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding TenKhachHang}" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="1" Text="{Binding SoDienThoai}" Margin="10,0" Foreground="{StaticResource ColorTextSecondary}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding DiemTichLuy, StringFormat={} {0} &#x0111;i&#x1EC3;m}" Foreground="{StaticResource ColorPrimary}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>
