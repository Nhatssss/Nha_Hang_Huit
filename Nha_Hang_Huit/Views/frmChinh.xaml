<Window x:Class="Nha_Hang_Huit.Views.frmChinh"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nh&#x00E0; H&#x00E0;ng HUIT - Qu&#x1EA3;n L&#xFD; Nh&#x00E0; H&#x00E0;ng"
        Height="640" Width="1000" WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{StaticResource ColorBackground}"
        FontFamily="{StaticResource AppFont}"
        TextOptions.TextFormattingMode="Display"
        xml:lang="vi-VN">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <Grid Margin="10" Background="{StaticResource ColorBackground}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header Bar -->
            <Border Grid.Row="0" Background="{StaticResource ColorPrimary}" CornerRadius="8" Padding="20,10" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="&#x1F3EA;" FontSize="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="NH&#x00C0; H&#x00C0;NG HUIT" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource ColorAccent}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Nh&#x00E2;n vi&#x00EA;n:" Foreground="#FFD7CCC8" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock x:Name="lblNhanVien" Text="admin" Foreground="White" FontSize="13"
                                   FontWeight="SemiBold" Margin="5,0,20,0" VerticalAlignment="Center"/>
                        <Button x:Name="btnMoCa" Content="M&#x1EDF; Ca" Style="{StaticResource BtnAccent}" Height="30" FontSize="12"
                                Padding="10,4" Click="btnMoCa_Click"/>
                        <Button x:Name="btnDongCa" Content="&#x0110;&#x00F3;ng Ca" Style="{StaticResource BtnPrimary}" Height="30"
                                FontSize="12" Padding="10,4" Click="btnDongCa_Click" Margin="5,0,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="lblCaHienTai" Text="CA: CH&#x1AF;A M&#x1EDF;" Foreground="#FFD7CCC8" FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Control Panel -->
            <Border Grid.Row="1" Background="{StaticResource ColorSurface}" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="5*"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Navigation Buttons -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="B&#x1EA2;NG &#x0110;I&#x1EC0;U KHI&#x1EC2;N" Style="{StaticResource TitleStyle}"/>
                        <WrapPanel>
                            <Button Content="G&#x1ECD;i M&#x00F3;n" Style="{StaticResource BtnPrimary}" Width="110" Height="36"
                                    Margin="2" Click="btnMenu_Click"/>
                            <Button Content="Thanh To&#x00E1;n" Style="{StaticResource BtnAccent}" Width="110" Height="36"
                                    Margin="2" Click="btnThanhToan_Click"/>
                            <Button Content="Kh&#x00E1;ch H&#x00E0;ng" Style="{StaticResource BtnPrimary}" Width="110" Height="36"
                                    Margin="2" Click="btnKhachHang_Click"/>
                            <Button Content="B&#x00E1;o C&#x00E1;o Ca" Style="{StaticResource BtnPrimary}" Width="110" Height="36"
                                    Margin="2" Click="btnBaoCao_Click"/>
                            <Button Content="Doanh Thu" Style="{StaticResource BtnAccent}" Width="110" Height="36"
                                    Margin="2" Click="btnBaoCaoDoanhThu_Click"/>
                        </WrapPanel>
                    </StackPanel>

                    <!-- Quick Stats -->
                    <Border Grid.Column="1" Background="{StaticResource ColorGoldLight}" CornerRadius="8" Padding="10"
                            Margin="10,0">
                        <StackPanel>
                            <TextBlock Text="TH&#x00D4;NG TIN NHANH" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource ColorAccent}"/>
                            <Grid Margin="0,5,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="H&#x00F3;a &#x0111;on:" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock x:Name="lblTongHoaDon" Text="0" Margin="5,0,0,0" FontSize="13"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Text="Doanh thu:" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock x:Name="lblDoanhThu" Text="0 VND" Margin="5,0,0,0" FontSize="13"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock x:Name="lblTrangThaiCa" Text="Ca hi&#x1EC7;n t&#x1EA1;i: #..." FontSize="11"
                                               Foreground="{StaticResource ColorTextSecondary}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Cart Summary -->
                    <Border Grid.Column="2" Background="{StaticResource ColorBrownLight}" CornerRadius="8" Padding="10">
                        <StackPanel>
                            <TextBlock Text="GI&#x1ECC; H&#x00C0;NG HI&#x1EC6;N T&#x1EA0;I" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource ColorPrimary}"/>
                            <Grid Margin="0,5,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="T&#x1ED5;ng ti&#x1EC1;n:" FontWeight="SemiBold" FontSize="12"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" x:Name="lblTongTien" Text="0 VND" FontWeight="Bold"
                                           Foreground="{StaticResource ColorPrimary}" Margin="5,0,10,0" FontSize="13"/>
                                <TextBlock Grid.Column="2" Text="Gi&#x1EA3;m gi&#x00E1;:" FontSize="12" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" x:Name="lblGiamGia" Text="0 VND" FontSize="12"
                                           Foreground="{StaticResource ColorWarning}"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                <TextBlock Text="Kh&#x00E1;ch h&#x00E0;ng:" FontSize="12" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="lblKhachHangInfo" Text="(Ch&#x01B0;a ch&#x1ECD;n)" FontSize="12"
                                           Margin="5,0,0,0" Foreground="{StaticResource ColorTextSecondary}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                <Button Content="X&#x00F3;a gi&#x1ECF; h&#x00E0;ng" Style="{StaticResource BtnPrimary}" Height="28"
                                        FontSize="11" Padding="8,2" Click="btnXoaGioHang_Click"/>
                                <Button x:Name="btnRefreshThongTin" Content="C&#x1EAD;p nh&#x1EAD;t" Style="{StaticResource BtnAccent}"
                                        Height="28" FontSize="11" Padding="8,2" Margin="5,0,0,0" Click="btnRefreshThongTin_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Main Content Area -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="5*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Quick Actions -->
                <Border Grid.Column="0" Background="{StaticResource ColorSurface}" CornerRadius="8" Padding="10" Margin="0,0,5,0">
                    <StackPanel>
                        <TextBlock Text="M&#x1EDB;I NH&#x1EA4;T" FontSize="14" FontWeight="Bold" Foreground="{StaticResource ColorPrimary}"/>
                        <TextBlock x:Name="lblThongBaoHienTai" Text="Ch&#x00E0;o m&#x1EEB;ng &#x0111;&#x1EBF;n v&#x1EDB;i Nh&#x00E0; H&#x00E0;ng HUIT!"
                                   TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource ColorTextSecondary}"
                                   Margin="0,5,0,10"/>

                        <Separator Background="{StaticResource ColorAccent}" Height="2" Margin="0,0,0,10"/>

                        <TextBlock Text="MENU NHANH" FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource ColorPrimary}"/>
                        <Button Content="T&#x00EC;m Kh&#x00E1;ch H&#x00E0;ng" Style="{StaticResource BtnPrimary}" Height="32"
                                FontSize="11" Margin="0,5" Click="btnTimKhachHang_Click"/>
                        <Button Content="Top M&#x00F3;n B&#x00E1;n Ch&#x1EA1;y" Style="{StaticResource BtnAccent}" Height="32"
                                FontSize="11" Margin="0,5" Click="btnTopMon_Click"/>
                        <Button Content="In H&#x00F3;a &#x0110;on M&#x1EAB;u" Style="{StaticResource BtnPrimary}" Height="32"
                                FontSize="11" Margin="0,5" Click="btnInHoaDonMau_Click"/>
                    </StackPanel>
                </Border>

                <!-- Center: Main view -->
                <Border Grid.Column="1" Background="{StaticResource ColorSurface}" CornerRadius="8" Padding="10" Margin="5,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" FontSize="16" FontWeight="Bold" Foreground="{StaticResource ColorPrimary}"
                                   Text="Trang ch&#x00ED;" Margin="0,0,0,5"/>
                        <!-- Content placeholder -->
                        <TextBlock Grid.Row="1" Text="Ch&#x1ECD;n ch&#x1EE9;c n&#x0103;ng t&#x1EEB; b&#x1EA3;ng &#x0111;i&#x1EC1;u khi&#x1EC3;n"
                                   Foreground="{StaticResource ColorTextSecondary}" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </Grid>
                </Border>

                <!-- Right: Cart detail -->
                <Border Grid.Column="2" Background="{StaticResource ColorSurface}" CornerRadius="8" Padding="10" Margin="5,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" FontSize="14" FontWeight="Bold" Foreground="{StaticResource ColorPrimary}"
                                   Text="Chi ti&#x1EBF;t gi&#x1ECF; h&#x00E0;ng" Margin="0,0,0,5"/>
                        <ListBox Grid.Row="1" x:Name="lstGioHang" BorderThickness="0"
                                 ItemsSource="{Binding}" DisplayMemberPath="TenMonAn"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>
