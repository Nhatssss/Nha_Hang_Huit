<Window x:Class="Nha_Hang_Huit.Views.frmMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="G&#x1ECD;i M&#x00F3;n - Nh&#x00E0; H&#x00E0;ng HUIT"
        Height="550" Width="900" WindowStartupLocation="CenterScreen"
        Background="{StaticResource ColorBackground}"
        FontFamily="{StaticResource AppFont}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource ColorPrimary}" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="&#x1F3EA;" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="G&#x1ECD;I M&#x00D3;N - MENU NH&#x00C0; H&#x00C0;NG" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource ColorAccent}"/>
                        <TextBlock x:Name="lblNhomSelected" Text="Ch&#x1ECD;n nh&#x00F3;m m&#x00F3;n &#x0103;n" FontSize="11" Foreground="#FFD7CCC8"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Nh&#x00F3;m: " FontSize="13" Foreground="White" VerticalAlignment="Center"/>
                        <ComboBox x:Name="lstNhomMon" Width="160" Height="30" FontSize="13"
                                  SelectionChanged="lstNhomMon_SelectionChanged"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Menu items + selection panel -->
                <Border Grid.Column="0" Background="{StaticResource ColorSurface}" CornerRadius="8" Padding="10" Margin="0,0,5,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="TH&#x1EF0;C &#x0110;ON" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource ColorPrimary}" Margin="0,0,0,8"/>

                        <ListBox Grid.Row="1" x:Name="lstMonAn" BorderThickness="0" FontSize="14"
                                 SelectionChanged="lstMonAn_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource ColorSurface}" CornerRadius="6" Padding="8" Margin="2"
                                            BorderBrush="#E0E0E0" BorderThickness="1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding TenMonAn}" FontWeight="SemiBold" FontSize="14"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Gia, StringFormat={}{0:N0} VND}"
                                                       FontWeight="Bold" Foreground="{StaticResource ColorAccent}" FontSize="14"/>
                                            <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding MoTa}" FontSize="11"
                                                       Foreground="{StaticResource ColorTextSecondary}" Margin="0,2,0,0"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Selection panel -->
                        <Border Grid.Row="2" x:Name="panelChonMon" Background="{StaticResource ColorGoldLight}" CornerRadius="6"
                                Padding="10" Margin="0,8,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="M&#x00F3;n: " FontWeight="SemiBold" FontSize="15"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="lblMonDaChon" Text="(ch&#x01B0;a ch&#x1ECD;n)" FontSize="15"
                                           VerticalAlignment="Center" Margin="0,0,15,0"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Gi&#x00E1;: " FontWeight="SemiBold" FontSize="15"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="0" Grid.Column="3" x:Name="lblGiaDaChon" Text="0 VND" FontSize="15"
                                           Foreground="{StaticResource ColorAccent}" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,15,0"/>

                                <StackPanel Grid.Row="1" Grid.ColumnSpan="5" Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button x:Name="btnGiamSL" Content="-" Style="{StaticResource BtnPrimary}"
                                            Width="30" Height="30" FontSize="14" FontWeight="Bold"
                                            Click="btnGiamSoLuong_Click"/>
                                    <TextBox x:Name="txtSoLuong" Text="1" Style="{StaticResource TxtField}"
                                             Width="60" Height="30" FontSize="14" TextAlignment="Center" Margin="5,0"/>
                                    <Button x:Name="btnTangSL" Content="+" Style="{StaticResource BtnAccent}"
                                            Width="30" Height="30" FontSize="14" FontWeight="Bold"
                                            Click="btnTangSoLuong_Click" Margin="0,0,10,0"/>
                                    <Button x:Name="btnThemVaoGio" Content="Th&#x00EA;m v&#x00E0;o gi&#x1ECF; h&#x00E0;ng"
                                            Style="{StaticResource BtnAccent}" Height="30" FontSize="12" Padding="12,4"
                                            Click="btnThemVaoGio_Click"/>
                                    <Button x:Name="btnXong" Content="Xong" Style="{StaticResource BtnPrimary}"
                                            Height="30" FontSize="12" Padding="12,4" Margin="10,0,0,0"
                                            Click="btnXong_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Right: Cart panel -->
                <Border Grid.Column="1" Background="{StaticResource ColorSurface}" CornerRadius="8" Padding="10" Margin="5,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="GI&#x1ECC; H&#x00C0;NG T&#x1EA0;M" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource ColorPrimary}" Margin="0,0,0,8"/>

                        <ListBox Grid.Row="1" x:Name="lstGioHangTam" BorderThickness="0" FontSize="13"
                                 DisplayMemberPath="TenMonAn" SelectionMode="Extended"
                                 SelectionChanged="lstGioHangTam_SelectionChanged"/>

                        <Separator Grid.Row="2" Background="{StaticResource ColorAccent}" Height="2" Margin="0,5"/>

                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="T&#x1ED5;ng c&#x1ED9;ng:" FontWeight="SemiBold" FontSize="14" Margin="0,5,0,0"/>
                                <TextBlock x:Name="lblTongGioHang" Text="0 VND" FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource ColorPrimary}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                                <Button x:Name="btnXoaChon" Content="X&#x00F3;a ch&#x1ECD;n" Style="{StaticResource BtnPrimary}"
                                        Height="30" FontSize="11" Padding="8,4" Margin="0,0,0,5" Click="btnXoaChon_Click"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>
