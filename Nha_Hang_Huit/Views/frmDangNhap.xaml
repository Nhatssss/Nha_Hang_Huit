<Window x:Class="Nha_Hang_Huit.Views.frmDangNhap"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="&#x0110;&#x0103;ng Nh&#x1EAD;p - Nh&#x00E0; H&#x00E0;ng HUIT"
        Height="420" Width="450" WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize" WindowStyle="SingleBorderWindow"
        Background="{StaticResource ColorBackground}"
        FontFamily="{StaticResource AppFont}"
        TextOptions.TextFormattingMode="Display"
        xml:lang="vi-VN">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid>
            <!-- Header -->
            <Border Background="{StaticResource ColorPrimary}" Height="130" VerticalAlignment="Top">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <TextBlock Text="&#x1F3EA;" FontSize="44" HorizontalAlignment="Center"/>
                    <TextBlock Text="NH&#x00C0; H&#x00C0;NG HUIT" FontSize="24" FontWeight="Bold" Foreground="{StaticResource ColorAccent}"
                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    <TextBlock Text="H&#x1EC7; th&#x1ED1;ng qu&#x1EA3;n l&#xFD; nh&#x00E0; h&#x00E0;ng" FontSize="12" Foreground="#FFD7CCC8"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Card dang nhap -->
            <Border Background="{StaticResource ColorSurface}" CornerRadius="10"
                    Margin="35,105,35,25" Padding="30,25">
                <StackPanel>
                    <TextBlock Text="&#x0110;&#x102;NG NH&#x1EAC;P" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource ColorPrimary}" HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <Label Content="T&#x00EA;n &#x0111;&#x0103;ng nh&#x1EAD;p:" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="txtTenDangNhap" Style="{StaticResource TxtField}" Margin="0,0,0,12"
                             Text="admin"/>

                    <Label Content="M&#x1EAD;t kh&#x1EA9;u:" Style="{StaticResource LabelStyle}"/>
                    <PasswordBox x:Name="txtMatKhau" Style="{StaticResource TxtField}" Margin="0,0,0,22"
                                 Height="34"/>

                    <Button x:Name="btnDangNhap" Content="&#x0110;&#x102;NG NH&#x1EAC;P" Style="{StaticResource BtnPrimary}"
                            Height="42" FontSize="15" Click="btnDangNhap_Click"/>

                    <TextBlock x:Name="lblThongBao" Foreground="{StaticResource ColorWarning}"
                               HorizontalAlignment="Center" Margin="0,10,0,0" Visibility="Collapsed"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>
