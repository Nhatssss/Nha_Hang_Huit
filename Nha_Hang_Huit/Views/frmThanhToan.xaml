<Window x:Class="Nha_Hang_Huit.Views.frmThanhToan"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thanh To&#x00E1;n - Nh&#x00E0; H&#x00E0;ng HUIT"
        Height="520" Width="800" WindowStartupLocation="CenterScreen"
        Background="{StaticResource ColorBackground}"
        FontFamily="{StaticResource AppFont}"
        TextOptions.TextFormattingMode="Display"
        xml:lang="vi-VN">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource ColorPrimary}" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                <TextBlock Text="&#x1F4B3; THANH TO&#x00C1;N" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource ColorAccent}" HorizontalAlignment="Center"/>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Cash Payment Panel -->
                <Border Grid.Column="0" Background="{StaticResource ColorSurface}" CornerRadius="8" Padding="20" Margin="0,0,5,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="THANH TO&#x00C1;N TI&#x1EC0;N M&#x1EB6;T" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource ColorPrimary}" Margin="0,0,0,15"/>

                        <TextBlock Grid.Row="1" Text="Chi ti&#x1EBF;t h&#x00F3;a &#x0111;on" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                        <ListBox Grid.Row="2" x:Name="lstHoaDonChiTiet" Height="100" BorderThickness="0" FontSize="12"
                                 DisplayMemberPath="TenMonAn"/>

                        <Separator Grid.Row="3" Background="{StaticResource ColorAccent}" Height="1" Margin="0,8"/>

                        <Grid Grid.Row="4" Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="T&#x1ED5;ng ti&#x1EC1;n h&#x00E0;ng:" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Grid.Column="2" x:Name="lblTongTien" Text="0 VND" FontSize="14" FontWeight="Bold"/>
                        </Grid>

                        <Grid Grid.Row="5" Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Gi&#x1EA3;m gi&#x00E1;:" FontWeight="SemiBold" FontSize="14"
                                       Foreground="{StaticResource ColorWarning}"/>
                            <TextBlock Grid.Column="2" x:Name="lblGiamGia" Text="0 VND" FontSize="14" Foreground="{StaticResource ColorWarning}"/>
                        </Grid>

                        <Separator Grid.Row="6" Background="{StaticResource ColorPrimary}" Height="2" Margin="0,5"/>

                        <Grid Grid.Row="7" Margin="0,5,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="THANH TO&#x00C1;N:" FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource ColorPrimary}"/>
                            <TextBlock Grid.Column="2" x:Name="lblThanhToan" Text="0 VND" FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource ColorAccent}"/>
                        </Grid>

                        <Grid Grid.Row="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.ColumnSpan="2">
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="S&#x1ED1; ti&#x1EC1;n kh&#x00E1;ch &#x0111;&#x01B0;a:" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" x:Name="txtTienKhachDua" Text="0" Style="{StaticResource TxtField}"
                                             FontSize="14" Margin="10,0,0,0" TextChanged="txtTienKhachDua_TextChanged"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Ti&#x1EC1;n th&#x1EEB;a:" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="lblTienThua" Text="0 VND" FontSize="14"
                                               Foreground="{StaticResource ColorSuccess}" FontWeight="Bold"/>
                                </Grid>

                                <TextBlock x:Name="lblThongBaoTT" Text="" Visibility="Collapsed"
                                           FontSize="12" Foreground="{StaticResource ColorWarning}"
                                           Margin="0,0,0,5" HorizontalAlignment="Center"/>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Ph&#x01B0;&#x01A1;ng th&#x1EE9;c:" FontSize="14" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" x:Name="cboPhuongThuc" Width="120" Margin="10,0,0,0"
                                              FontSize="13" SelectedIndex="0">
                                        <ComboBoxItem Content="Ti&#x1EC1;n M&#x1EB7;t" IsSelected="True"/>
                                        <ComboBoxItem Content="Chuy&#x1EC3;n kho&#x1EA3;n"/>
                                        <ComboBoxItem Content="Th&#x1EBB;"/>
                                    </ComboBox>
                                </Grid>

                                <Button x:Name="btnXacNhanTT" Content="X&#x00C1;C NH&#x1EAC;N THANH TO&#x00C1;N"
                                        Style="{StaticResource BtnAccent}" Height="40" FontSize="14"
                                        Click="btnXacNhanTT_Click"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- QR Payment Panel -->
                <Border Grid.Column="1" Background="{StaticResource ColorSurface}" CornerRadius="8" Padding="20" Margin="5,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="THANH TO&#x00C1;N QR CODE" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource ColorPrimary}" Margin="0,0,0,15"/>

                        <Button Grid.Row="1" x:Name="btnTaoQR" Content="T&#x1EA1;o QR Code" Style="{StaticResource BtnPrimary}"
                                Height="36" FontSize="13" Click="btnTaoQR_Click"/>

                        <Border Grid.Row="2" x:Name="qrBorder" Background="White" CornerRadius="8"
                                BorderBrush="{StaticResource ColorAccent}" BorderThickness="2"
                                Margin="0,10" Width="250" Height="250" HorizontalAlignment="Center">
                            <Grid>
                                <Image x:Name="imgQRCode" Stretch="Uniform" Margin="5" Visibility="Collapsed"/>
                                <TextBlock x:Name="lblQRInfo" Text="B&#x1EA5;m n&#x00FA;t &#x0111;&#x1EC3; t&#x1EA1;o m&#x00E3; QR"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{StaticResource ColorTextSecondary}" FontSize="13"
                                           TextWrapping="Wrap" TextAlignment="Center"/>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="3">
                            <Border x:Name="panelQRCountdown" Background="{StaticResource ColorWarning}" CornerRadius="4"
                                    Padding="8,4" Margin="0,5" HorizontalAlignment="Center" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Th&#x1EDD;i gian ch&#x1EDD;: " FontSize="12" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="lblQRCountdown" Text="30s" FontSize="16" FontWeight="Bold" Foreground="White"/>
                                </StackPanel>
                            </Border>
                            <TextBlock x:Name="lblQRResult" Text="Ch&#x1EDD; x&#x00E1;c nh&#x1EAD;n thanh to&#x00E1;n..."
                                       FontSize="12" Foreground="{StaticResource ColorTextSecondary}"
                                       HorizontalAlignment="Center" Visibility="Collapsed"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                                <Button x:Name="btnGiaLapQR" Content="Gi&#x1EA3; l&#x1EAD;p thanh to&#x00E1;n QR"
                                        Style="{StaticResource BtnAccent}" Height="30" FontSize="11"
                                        Padding="10,4" Click="btnGiaLapQR_Click"/>
                                <Button x:Name="btnHuy" Content="H&#x1EE7;y h&#x00F3;a &#x0111;on"
                                        Foreground="White" Background="Red" Height="30" FontSize="11"
                                        Padding="10,4" Margin="8,0,0,0"
                                        Click="btnHuy_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>
