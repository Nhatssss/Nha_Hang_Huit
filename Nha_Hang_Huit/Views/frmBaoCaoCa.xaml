<Window x:Class="Nha_Hang_Huit.Views.frmBaoCaoCa"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="B&#x00E1;o C&#x00E1;o &#x0110;&#x00F3;ng Ca - Nh&#x00E0; H&#x00E0;ng HUIT"
        Height="500" Width="700" WindowStartupLocation="CenterScreen"
        Background="{StaticResource ColorBackground}"
        FontFamily="{StaticResource AppFont}"
        TextOptions.TextFormattingMode="Display"
        xml:lang="vi-VN">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource ColorPrimary}" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="B&#x00C1;O C&#x00C1;O &#x0110;&#x00D3;NG CA" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource ColorAccent}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="lblMaCa" Text="Ca #..." FontSize="12" Foreground="#FFD7CCC8"
                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Content -->
            <Border Grid.Row="1" Background="{StaticResource ColorSurface}" CornerRadius="8" Padding="20" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Summary -->
                    <Border Grid.Row="0" Background="{StaticResource ColorGoldLight}" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="&#x1F4C5; Th&#x1EDD;i gian" FontWeight="Bold" FontSize="13" Foreground="{StaticResource ColorTextSecondary}"/>
                                <TextBlock x:Name="lblGioBatDau" Text="B&#x1EAF;t &#x0111;&#x1EA7;u: --" FontSize="12" Margin="0,3,0,0"/>
                                <TextBlock x:Name="lblGioKetThuc" Text="K&#x1EBF;t th&#x00FA;c: --" FontSize="12"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="5,0">
                                <TextBlock Text="&#x1F464; Nh&#x00E2;n vi&#x00EA;n" FontWeight="Bold" FontSize="13" Foreground="{StaticResource ColorTextSecondary}"/>
                                <TextBlock x:Name="lblNhanVien" Text="--" FontSize="12" Margin="0,3,0,0"/>
                                <TextBlock x:Name="lblTongHoaDon" Text="T&#x1ED5;ng h&#x00F3;a &#x0111;on: 0" FontSize="12"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="10,0,0,0">
                                <TextBlock Text="&#x1F4B0; Doanh thu" FontWeight="Bold" FontSize="13" Foreground="{StaticResource ColorTextSecondary}"/>
                                <TextBlock x:Name="lblDoanhThuTruocGiam" Text="Tr&#x01B0;&#x1EDB;c gi&#x1EA3;m: 0 VND" FontSize="12" Margin="0,3,0,0"/>
                                <TextBlock x:Name="lblTongGiamGia" Text="Gi&#x1EA3;m gi&#x00E1;: 0 VND" FontSize="12"/>
                            </StackPanel>

                            <Border Grid.Row="1" Grid.ColumnSpan="3"
                                    Background="{StaticResource ColorPrimary}" CornerRadius="6" Padding="10" Margin="0,10,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Th&#x1EF1;c nh&#x1EAD;n:" FontSize="15" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Grid.Column="1" x:Name="lblDoanhThuThucNhan" Text="0 VND" FontSize="18" FontWeight="Bold"
                                               Foreground="{StaticResource ColorAccent}"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Additional stats -->
                    <TextBlock Grid.Row="1" x:Name="lblSoKhachMoi" Text="Kh&#x00E1;ch m&#x1EDB;i: 0"
                               FontSize="13" Foreground="{StaticResource ColorTextSecondary}" Margin="0,0,0,8"/>

                    <!-- Top 5 items -->
                    <TextBlock Grid.Row="2" Text="TOP 5 M&#x00D3;N &#x0102;N B&#x00C1;N CH&#x1EA0;Y" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource ColorPrimary}" Margin="0,0,0,8"/>
                    <ListBox Grid.Row="3" x:Name="lstTopMon" BorderThickness="1" BorderBrush="#E0E0E0"
                             FontSize="13" Height="180">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="4" Padding="6" Margin="1" Background="{StaticResource ColorSurface}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding STT}" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="1" Text="{Binding TenMonAn}" Margin="5,0"/>
                                        <TextBlock Grid.Column="2" Text="{Binding SoLuong}" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding DoanhThu, StringFormat={}{0:N0} VND}"
                                                   HorizontalAlignment="Right" Foreground="{StaticResource ColorAccent}" FontWeight="Bold"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Footer buttons -->
            <Border Grid.Row="2" Background="{StaticResource ColorSurface}" CornerRadius="8" Padding="10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnXuatBaoCao" Content="Xu&#x1EA5;t b&#x00E1;o c&#x00E1;o (.txt)"
                            Style="{StaticResource BtnAccent}" Height="34" FontSize="12" Padding="12,6"
                            Click="btnXuatBaoCao_Click"/>
                    <Button x:Name="btnDong" Content="&#x0110;&#x00F3;ng" Style="{StaticResource BtnPrimary}"
                            Height="34" FontSize="12" Padding="20,6" Margin="10,0,0,0"
                            Click="btnDong_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>
